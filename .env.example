# ============================================================================
# MediaIndexer configuration. Copy to ".env" and fill in the values.
# ============================================================================

# ---- Telegram (userbot / MTProto client API) -------------------------------
# From https://my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=
# StringSession from scripts/generate_session.py (a secret credential!)
TG_SESSION=
# Numeric user id of the owning account. Commands are only accepted from this id.
OWNER_ID=

# Source chats/threads read as an event stream (comma-separated chat ids).
# Supergroup ids usually look like -1001234567890.
SOURCE_CHAT_IDS=
# Where media cards are published.
TARGET_CHAT_ID=
# Forum topic id to post into (0 = no topic / normal group).
TARGET_TOPIC_ID=0
# Command prefix for owner commands.
COMMAND_PREFIX=.

# ---- MongoDB ---------------------------------------------------------------
# Inside docker-compose this is overridden to mongodb://mongo:27017
MONGO_URI=mongodb://mongo:27017
MONGO_DB=mediaindexer

# ---- External metadata providers -------------------------------------------
# TMDb is the primary source for films/series. Get a key at themoviedb.org.
TMDB_API_KEY=
# OMDb is the fallback. Get a key at omdbapi.com.
OMDB_API_KEY=
# Optional: official MyAnimeList client id (anime uses Jikan by default, no key).
MAL_CLIENT_ID=
# Metadata language for TMDb.
TMDB_LANGUAGE=de-DE
# How long provider lookups are cached (days).
PROVIDER_CACHE_TTL_DAYS=30

# ---- Pipeline / processing rules -------------------------------------------
MAX_CONTENT_LINES=3
QUEUE_MAXSIZE=1000
ITEM_TIMEOUT_SECONDS=45
RECENT_EVENTS_KEEP=50
# Fuzzy thresholds (0-100).
TITLE_MATCH_THRESHOLD=86
PROVIDER_MATCH_THRESHOLD=78
# Minimum confidence (0-1) before a weak text-only title is trusted.
CLASSIFY_MIN_CONFIDENCE=0.45

# ---- UI / posting ----------------------------------------------------------
TG_MESSAGE_LIMIT=3900
# Photo captions are limited by Telegram (1024 for non-premium). The root post
# shows the poster as a photo + caption, so its first chunk respects this.
TG_CAPTION_LIMIT=1024
# The overview is rendered as an expandable (collapsed) blockquote and capped to
# this many characters so it fits the caption and stays tidy.
OVERVIEW_MAX_CHARS=600
EPISODES_FULL_LIMIT=20
EPISODES_BLOCK_LIMIT=100
EPISODES_GROUP_LIMIT=1000
# Up to this many total episodes, EVERY episode is an individual clickable link
# inside per-season collapsible blockquotes (oversized seasons split into
# several). Above it, seasons collapse to one line linking the first episode.
EPISODES_LINK_LIMIT=600

# When 'true', media without a successful provider match are NOT posted to the
# target thread. They stay catalogued and are posted automatically once the
# healer resolves their metadata. Default 'false' (post with detection data).
# Thread/topic IDs (comma-separated) whose files are anime: the resolver tries
# the anime providers (Jikan/AniList/Kitsu) BEFORE TMDb/OMDb for these.
# Max. Formatierungs-Entities (Links/Fett/Blockquote) pro Telegram-Nachricht.
# Telegram verwirft alles ueber ~100 als Klartext; 90 laesst Sicherheitsmarge.
TG_MAX_ENTITIES=90

ANIME_SOURCE_THREAD_IDS=

POST_ONLY_IF_RESOLVED=false

# ---- Flood control / send pacing (userbot anti-spam) -----------------------
# Minimum seconds between message-mutating Telegram calls (send/edit/delete).
# Raising this is safer for the account; lowering it posts faster but risks
# Telegram imposing large FloodWait penalties during big imports.
SEND_MIN_INTERVAL=3.0
# Telethon auto-sleeps FloodWaits up to this many seconds instead of raising.
FLOOD_SLEEP_THRESHOLD=300
# Hard cap: a FloodWait larger than the threshold is waited out and retried,
# but never longer than this many seconds.
FLOOD_WAIT_MAX=1800

# ---- Healing ---------------------------------------------------------------
HEAL_INTERVAL_SECONDS=900
PENDING_MAX_ATTEMPTS=5

# ---- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
ANIME_MATCH_THRESHOLD=88
UPDATE_LOOP_MAX=6
UPDATE_FAIL_MAX=3
UPDATE_SYNC_TIMEOUT=120
AUDIOBOOK_SOURCE_THREAD_IDS=
IGNORE_THREAD_IDS=
GOOGLE_BOOKS_API_KEY=
AUDNEXUS_REGION=de
BOOKS_LANGUAGE=de
AUDIOBOOK_MATCH_THRESHOLD=75
IGNORE_ARCHIVE_FILES=true
TRAILER_KEYWORDS=
